	measure 'SVG Status Talhao' =
			
			VAR _DataAtual =
			    MAX(dim_calendario[data])
			
			VAR _IdStatus =
			    CALCULATE(
			        SELECTEDVALUE(fato_saude_talhao[id_status]),
			        dim_calendario[data] = _DataAtual
			    )
			
			VAR _Status =
			    LOOKUPVALUE(
			        dim_status_talhao[status_talhao],
			        dim_status_talhao[id_status], _IdStatus
			    )
			
			VAR _CorHexOriginal =
			    LOOKUPVALUE(
			        dim_status_talhao[cor_hex],
			        dim_status_talhao[id_status], _IdStatus
			    )
			
			VAR _OrdemStatus =
			    LOOKUPVALUE(
			        dim_status_talhao[ordem_status],
			        dim_status_talhao[id_status], _IdStatus
			    )
			
			VAR _CorStatus =
			    SUBSTITUTE(
			        COALESCE(_CorHexOriginal, "#C0C0C0"),
			        "#",
			        "%23"
			    )
			
			VAR _CorTexto =
			    IF(_OrdemStatus IN {1,2,4}, "black","white")
			
			VAR _TextoSvg =
			    SUBSTITUTE(
			        COALESCE(_Status, "Sem status"),
			        "&",
			        "&amp;"
			    )
			
			VAR _Svg =
			    "data:image/svg+xml;utf8," &
			    "<svg xmlns='http://www.w3.org/2000/svg' width='180' height='52' viewBox='0 0 180 52'>" &
			        "<rect x='1' y='4' rx='14' ry='14' width='178' height='44' fill='" & _CorStatus & "' />" &
			        "<text x='90' y='31' text-anchor='middle' font-family='Segoe UI' font-size='16' font-weight='600' fill='" & _CorTexto & "'>" &
			            _TextoSvg &
			        "</text>" &
			    "</svg>"
			
			RETURN
			    _Svg
		displayFolder: 00.Geral\01.Monitoramento
		lineageTag: 59671481-a6da-4df7-bac2-c67bfe42331a

	partition Medidas = m
		mode: import
		source =
				let
				    Fonte = Table.FromRows(Json.Document(Binary.Decompress(Binary.FromText("i44FAA==", BinaryEncoding.Base64), Compression.Deflate)), let _t = ((type nullable text) meta [Serialized.Text = true]) in type table [#"Coluna 1" = _t]),
				    #"Colunas Removidas" = Table.RemoveColumns(Fonte,{"Coluna 1"})
				in
				    #"Colunas Removidas"

	annotation PBI_NavigationStepName = Navegação

	annotation PBI_ResultType = Table


			                    <div class='legenda'><span class='dot amarelo'></span>Atenção</div>
			                    <div class='legenda'><span class='dot vermelho'></span>Críticos</div>
			                </div>
			            </div>
			        </div>
			
			        " & _HtmlLinhas & "
			
			    </div>
			</div>
			"

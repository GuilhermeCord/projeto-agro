	measure 'Cor % Variação Talhoes Criticos - MoM' =
			
			VAR _Valor = [% Variação Talhoes Criticos - MoM]
			RETURN
			
			SWITCH(
			    TRUE(),
			    _Valor < 0, "#00AA85",
			    _Valor > 0, "#ED3559",
			    _Valor = 0, "#777A8D"
			)
		displayFolder: 00.Geral\04. Formatações Condicionais
		lineageTag: 29ba2c22-9dd0-473e-8595-751b86396b0b

	measure 'Hectares Monitorados' =
			
			SUM(fato_saude_talhao[area_saudavel_ha]) + SUM(fato_saude_talhao[area_critica_ha]) + SUM(fato_saude_talhao[area_atencao_ha])
		displayFolder: 00.Geral\01.Monitoramento
		lineageTag: 397b57a7-0e4b-44c5-ae4f-c6f9ca224f9e

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Hectares Saudaveis' =
			
			SUM(fato_saude_talhao[area_saudavel_ha])
		displayFolder: 00.Geral\01.Monitoramento
		lineageTag: 16e3fbcf-6be7-42bd-b1d3-e5f80c277cb7

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Hectares Criticos' =
			
			SUM(fato_saude_talhao[area_critica_ha])
		displayFolder: 00.Geral\01.Monitoramento
		lineageTag: f7525333-01a6-4d01-8ce5-cca94658c793

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Hectares Atenção' =
			
			SUM(fato_saude_talhao[area_atencao_ha])
		displayFolder: 00.Geral\01.Monitoramento
		lineageTag: 0959481f-efac-4264-8e99-a3ab1076d6ff

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Ultima atualização da Fazenda' =
			
			CALCULATE(
			    MAX(fato_notificacoes[data_hora]),
			    ALL(dim_calendario),
			    ALL(dim_talhao)
			)
		formatString: General Date
		displayFolder: 00.Geral\01.Monitoramento
		lineageTag: 1fafbe51-06e6-44d0-a6d8-bf5bf1b8a2aa

	partition Medidas = m
		mode: import
		source =
				let
				    Fonte = Table.FromRows(Json.Document(Binary.Decompress(Binary.FromText("i44FAA==", BinaryEncoding.Base64), Compression.Deflate)), let _t = ((type nullable text) meta [Serialized.Text = true]) in type table [#"Coluna 1" = _t]),
				    #"Colunas Removidas" = Table.RemoveColumns(Fonte,{"Coluna 1"})
				in

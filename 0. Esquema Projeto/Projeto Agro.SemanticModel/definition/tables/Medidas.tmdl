		lineageTag: 7dedd7ad-aa07-487a-a1a6-39cea46c26d8

	measure 'Cor % Variação Talhoes Criticos - MoM' =
			
			VAR _Valor = [% Variação Talhoes Criticos - MoM]
			RETURN
			
			SWITCH(
			    TRUE(),
			    _Valor < 0, "#00AA85",
			    _Valor > 0, "#ED3559",
			    _Valor = 0, "#777A8D"
			)
		displayFolder: 00.Geral\04. Formatações Condicionais
		lineageTag: 29ba2c22-9dd0-473e-8595-751b86396b0b

	measure 'Hectares Monitorados' =
			
			SUM(fato_saude_talhao[area_saudavel_ha]) + SUM(fato_saude_talhao[area_critica_ha]) + SUM(fato_saude_talhao[area_atencao_ha])
		displayFolder: 00.Geral\01.Monitoramento
		lineageTag: 397b57a7-0e4b-44c5-ae4f-c6f9ca224f9e

		annotation PBI_FormatHint = {"isGeneralNumber":true}

	measure 'Hectares Saudaveis' =
			

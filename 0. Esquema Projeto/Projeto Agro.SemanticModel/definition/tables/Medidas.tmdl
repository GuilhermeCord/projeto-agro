	measure 'Vs Periodo Anterior' =
			
			VAR _TemMes =
			    HASONEVALUE(dim_calendario[nome_mes])
			
			VAR _TemAno =
			    HASONEVALUE(dim_calendario[ano])
			
			VAR _DataAnterior =
			    CALCULATE(
			        MAX(dim_calendario[data]),
			        DATEADD(dim_calendario[data], -1, MONTH)
			    )
			
			VAR _MesAnterior =
			    CALCULATE(
			        SELECTEDVALUE(dim_calendario[nome_mes]),
			        DATEADD(dim_calendario[data], -1, MONTH)
			    )
			
			VAR _AnoAnteriorMes =
			    CALCULATE(
			        SELECTEDVALUE(dim_calendario[ano]),
			        DATEADD(dim_calendario[data], -1, MONTH)
			    )
			
			VAR _AnoAnterior =
			    SELECTEDVALUE(dim_calendario[ano]) - 1
			
			RETURN
			SWITCH(
			    TRUE(),
			    _TemMes && _TemAno,
			        "vs " & _MesAnterior & "/" & _AnoAnteriorMes & ":",
			
			    _TemAno,
			        "vs " & _AnoAnterior & ":",
			
			    " "
			)
		displayFolder: 00.Geral\04. Formatações Condicionais
		lineageTag: 2d684fc7-3002-4ee3-80af-5ee623552584


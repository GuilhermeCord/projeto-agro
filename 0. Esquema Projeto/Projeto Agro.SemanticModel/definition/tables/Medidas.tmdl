	measure 'SVG Hectares Analise' =
			
			VAR _Saudaveis = [Hectares Saudaveis]
			VAR _Atencao = [Hectares Atenção]
			VAR _Criticos = [Hectares Criticos]
			VAR _Total = [Hectares Monitorados]
			
			VAR _BarraTotal = 380
			VAR _AlturaBarra = 34
			VAR _YBarra = 18
			
			VAR _WSaudaveis = ROUND(DIVIDE(_Saudaveis, _Total, 0) * _BarraTotal, 0)
			VAR _WAtencao = ROUND(DIVIDE(_Atencao, _Total, 0) * _BarraTotal, 0)
			VAR _WCriticos = _BarraTotal - _WSaudaveis - _WAtencao
			
			VAR _XAtencao = _WSaudaveis
			VAR _XCriticos = _WSaudaveis + _WAtencao
			
			VAR _CorTextoHex = SELECTEDVALUE(d_temas[Texto], "#FFFFFF")
			VAR _CorTexto = SUBSTITUTE(_CorTextoHex, "#", "%23")
			
			VAR _Svg =
			    "data:image/svg+xml;utf8," &
			    "<svg xmlns='http://www.w3.org/2000/svg' width='500' height='90' viewBox='0 0 500 90'>" &
			
			        "<rect x='0' y='" & _YBarra & "' rx='7' ry='7' width='" & _BarraTotal & "' height='" & _AlturaBarra & "' fill='%23E5E7EB'/>" &
			
			        "<rect x='0' y='" & _YBarra & "' rx='7' ry='7' width='" & _WSaudaveis & "' height='" & _AlturaBarra & "' fill='%23699056'/>" &
			
			        "<rect x='" & _XAtencao & "' y='" & _YBarra & "' width='" & _WAtencao & "' height='" & _AlturaBarra & "' fill='%23F4C169'/>" &
			
			        "<rect x='" & _XCriticos & "' y='" & _YBarra & "' rx='7' ry='7' width='" & _WCriticos & "' height='" & _AlturaBarra & "' fill='%23D64550'/>" &
			
			        "<text x='" & DIVIDE(_WSaudaveis, 2, 0) & "' y='40' text-anchor='middle' font-family='Segoe UI' font-size='15' font-weight='800' fill='white'>" &
			            FORMAT(_Saudaveis, "0.00") &
			        "</text>" &
			
			        "<text x='" & (_XAtencao + DIVIDE(_WAtencao, 2, 0)) & "' y='40' text-anchor='middle' font-family='Segoe UI' font-size='15' font-weight='800' fill='black'>" &
			            FORMAT(_Atencao, "0.00") &
			        "</text>" &
			
			        "<text x='" & (_XCriticos + DIVIDE(_WCriticos, 2, 0)) & "' y='40' text-anchor='middle' font-family='Segoe UI' font-size='15' font-weight='800' fill='white'>" &
			            FORMAT(_Criticos, "0.00") &
			        "</text>" &
			
			        "<text x='395' y='42' font-family='Segoe UI' font-size='20' font-weight='900' fill='" & _CorTexto & "'>" &
			            FORMAT(_Total, "0.00") & " ha" &
			        "</text>" &
			
			    "</svg>"
			
			RETURN
			    _Svg
		displayFolder: 00.Geral\01.Monitoramento
		lineageTag: 6cc07324-34f7-423b-a529-e49231b11293
		dataCategory: ImageUrl

	measure 'HTML Tabela Talhoes' = ```
			
			VAR _Tema = SELECTEDVALUE(d_temas[ID])
			VAR _CorTema =
			    SWITCH(
			        _Tema,
			        1, "#383838",
			        2, "#FFFFFF",
			        "#383838"
			    )
			VAR _CorTituloTema = SELECTEDVALUE(d_temas[Texto])
			VAR _CorSubTituloTema = SELECTEDVALUE(d_temas[SubTitulo])
			VAR _HtmlLinhas =
			    CONCATENATEX(
			        VALUES(dim_talhao[nome_talhao]),
			        VAR _Talhao = dim_talhao[nome_talhao]
			
			        VAR _DataAtual = MAX(dim_calendario[data])
			
			        VAR _IdCultura =
			            CALCULATE(
			                SELECTEDVALUE(fato_saude_talhao[id_cultura]),
			                dim_calendario[data] = _DataAtual
			            )
			
			        VAR _Cultura =
			            COALESCE(
			                LOOKUPVALUE(
			                    dim_cultura[cultura],
			                    dim_cultura[id_cultura], _IdCultura
			                ),
			                "-"
			            )
			
			        VAR _Status = SUBSTITUTE(CALCULATE([SVG Status Talhao]), """", "'")
			        VAR _Score = SUBSTITUTE(CALCULATE([SVG Score Saude]), """", "'")
			
			        VAR _Saudaveis = [Hectares Saudaveis]
			        VAR _Atencao = [Hectares Atenção]
			        VAR _Criticos = [Hectares Criticos]
			        VAR _Total = [Hectares Monitorados]
			
			        VAR _PercSaudaveis = DIVIDE(_Saudaveis, _Total, 0) * 100
			        VAR _PercAtencao = DIVIDE(_Atencao, _Total, 0) * 100
			        VAR _PercCriticos = DIVIDE(_Criticos, _Total, 0) * 100
			        VAR _LimiteLabel = 8
			
			        VAR _Tema = SELECTEDVALUE(d_temas[ID])
			        VAR _CorTema = SWITCH(
			                        _Tema,
			                         1,"#383838",
			                         2,"#FFFFFF"
			                    )
			
			        RETURN
			        "
			        <div class='row'>
			            <div class='talhao'>" & _Talhao & "</div>
			            <div class='cultura'>" & _Cultura & "</div>
			            <div class='status'><img class='img-status' src=""" & _Status & """></div>
			            <div class='score'><img class='img-score' src=""" & _Score & """></div>
			
			            <div class='analise'>
			                <div class='barra-area'>
			                    <div class='barra'>
			                        <div class='seg verde' style='width:" & FORMAT(_PercSaudaveis, "0.00", "en-US") & "%'>" &
			                            IF(_PercSaudaveis >= _LimiteLabel, FORMAT(_Saudaveis, "0.00"), "") &
			                        "</div>
			
			                        <div class='seg amarelo' style='width:" & FORMAT(_PercAtencao, "0.00", "en-US") & "%'>" &
			                            IF(_PercAtencao >= _LimiteLabel, FORMAT(_Atencao, "0.00"), "") &
			                        "</div>
			
			                        <div class='seg vermelho' style='width:" & FORMAT(_PercCriticos, "0.00", "en-US") & "%'>" &
			                            IF(_PercCriticos >= _LimiteLabel, FORMAT(_Criticos, "0.00"), "") &
			                        "</div>
			                    </div>
			
			                    <div class='valores-barra'>
			                        <div class='valor v-verde' style='width:" & FORMAT(_PercSaudaveis, "0.00", "en-US") & "%'>" &
			                            IF(_PercSaudaveis < _LimiteLabel, FORMAT(_Saudaveis, "0.00"), "") &
			                        "</div>
			
			                        <div class='valor v-amarelo' style='width:" & FORMAT(_PercAtencao, "0.00", "en-US") & "%'>" &
			                            IF(_PercAtencao < _LimiteLabel, FORMAT(_Atencao, "0.00"), "") &
			                        "</div>
			
			                        <div class='valor v-vermelho' style='width:" & FORMAT(_PercCriticos, "0.00", "en-US") & "%'>" &
			                            IF(_PercCriticos < _LimiteLabel, FORMAT(_Criticos, "0.00"), "") &
			                        "</div>
			                    </div>
			                </div>
			
			                <div class='total'>" & FORMAT(_Total, "0.00") & " ha</div>
			            </div>
			        </div>
			        ",
			        ""
			    )
			
			RETURN
			"
			<style>
			* {
			    box-sizing: border-box;
			}
			
			.tabela-container {
			    width: 1840px;
			    height: 275px;
			    overflow-y: auto;
			    overflow-x: hidden;
			    background: " & _CorTema & ";
			    border: none;
			    outline: none;
			    box-shadow: none;
			}
			
			.cabecalho-fixo {
			    position: sticky;
			    top: 0;
			    z-index: 999;
			    background: " & _CorTema & ";
			    border: none;
			    outline: none;
			    box-shadow: none;
			}
			
			.tabela {
			    width: 1830px;
			    min-width: 1830px;
			    overflow: visible;
			    border: none;
			    outline: none;
			    box-shadow: none;
			}
			
			.score {
			    display: flex;
			    justify-content: center;
			    align-items: center;
			}
			.status {
			    display: flex;
			    justify-content: center;
			    align-items: center;
			}
			.tabela-container::-webkit-scrollbar {
			    width: 12px;
			}
			
			.tabela-container::-webkit-scrollbar-track {
			    background: " & _CorTema & ";
			}
			
			.tabela-container::-webkit-scrollbar-thumb {
			    background: #605E5C;
			    border-radius: 10px;
			}
			
			.tabela-container::-webkit-scrollbar-thumb:hover {
			    background: #605E5C;
			}
			
			.header-legenda,
			.header-titulos,
			.row {
			    display: grid;
			    grid-template-columns: 200px 200px 200px 200px 950px;
			    column-gap: 12px;
			    align-items: center;
			    color: " & _CorTituloTema & ";
			    background: " & _CorTema & ";
			    border: none;
			    outline: none;
			    box-shadow: none;
			}
			
			.row {
			    padding: 0 18px;
			    min-height: 82px;
			  
			}
			
			
			
			.header-titulos {
			    font-size: 16px;
			    font-weight: 600;
			    padding: 8px 18px 4px 18px;
			    color: " & _CorSubTituloTema & ";
			    text-align: center;
			}
			
			.header-legenda {
			    padding: 2px 18px 10px 18px;
			    border-bottom: 2px solid #E6E6E6;
			    
			}
			.legendas {
			    width: 928px;
			    display: flex;
			    justify-content: space-around;
			    align-items: center;
			    color: " & _CorSubTituloTema & ";
			}
			
			.legenda {
			    display: flex;
			    align-items: center;
			    gap: 9px;
			    font-size: 16px;
			    font-weight: 600;
			}
			
			.titulo-analise {
			    width: 928px;
			    text-align: center;
			    font-size: 16px;
			    font-weight: 600;
			    color: " & _CorSubTituloTema & ";
			}
			
			.analise {
			    width: 928px;
			    display: grid;
			    grid-template-columns: 760px 140px;
			    column-gap: 28px;
			    align-items: start;
			}
			
			
			.talhao,
			.cultura {
			    font-size: 16px;
			    font-weight: 600;
			    white-space: nowrap;
			}
			
			.img-status {
			    width: 150px;
			    height: 44px;
			    display: block;
			}
			
			.img-score {
			    width: 160px;
			    height: 56px;
			    display: block;
			
			}
			
			
			
			.dot {
			    width: 16px;
			    height: 16px;
			    border-radius: 50%;
			    display: inline-block;
			}
			
			
			
			.barra-area {
			    width: 760px;
			}
			
			.barra {
			    display: flex;
			    width: 760px;
			    height: 40px;
			    border-radius: 8px;
			    overflow: hidden;
			    background: #e5e7eb;
			}
			
			.seg {
			    height: 40px;
			    display: flex;
			    align-items: center;
			    justify-content: center;
			    font-size: 14px;
			    font-weight: 600;
			    white-space: nowrap;
			    overflow: hidden;
			}
			
			.verde {
			    background: #699056;
			    color: #ffffff;
			}
			
			.amarelo {
			    background: #f4c169;
			    color: #000000;
			}
			
			.vermelho {
			    background: #d64550;
			    color: #ffffff;
			}
			
			.valores-barra {
			    display: flex;
			    width: 760px;
			    margin-top: 5px;
			    height: 14px;
			}
			
			.valor {
			    text-align: center;
			    font-size: 14px;
			    font-weight: 600;
			    white-space: nowrap;
			    overflow: visible;
			}
			
			.v-verde {
			    color: #8fc77a;
			}
			
			.v-amarelo {
			    color: #f4c169;
			}
			
			.v-vermelho {
			    color: #ff6b76;
			}
			
			.total {
			    font-size: 16px;
			    font-weight: 600;
			    white-space: nowrap;
			    height: 40px;
			    display: flex;
			    align-items: center;
			}
			</style>
			
			<div class='tabela-container'>
			    <div class='tabela'>
			
			        <div class='cabecalho-fixo'>
			            <div class='header-titulos'>
			                <div>Talhão</div>
			                <div>Cultura</div>
			                <div>Status</div>
			                <div>Score de Saúde Médio</div>
